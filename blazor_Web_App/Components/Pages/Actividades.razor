@page "/Actividades"
@rendermode InteractiveServer

<h3>Lista de actividades</h3>

<div class="mb-3">
    <label>Nueva actividad</label>
    <input type="text" class="form-control" @bind="nuevaActividad" />
</div>

<button class="btn btn-success mb-3" @onclick="AgregarActividad">
    Agregar actividad
</button>

<h4>Actividades por realizar</h4>

@if (actividades.Any())
{
    <ul class="list-group">
        @foreach (var actividad in actividades)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                @actividad
                <button class="btn btn-danger btn-sm" @onclick="() => EliminarActividad(actividad)">
                    Eliminar
                </button>
            </li>
        }
    </ul>
}
else
{
    <p>No hay actividades registradas.</p>
}

@code {
    private string nuevaActividad = "";
    private List<string> actividades = new List<string>();

    private void AgregarActividad()
    {
        if (!string.IsNullOrWhiteSpace(nuevaActividad))
        {
            actividades.Add(nuevaActividad);
            nuevaActividad = "";
        }
    }

    private void EliminarActividad(string actividad)
    {
        actividades.Remove(actividad);
    }
}